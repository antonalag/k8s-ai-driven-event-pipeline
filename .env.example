# ══════════════════════════════════════════════════════════════════════════════
# Environment Configuration — k8s-ai-driven-event-pipeline
#
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# The bootstrap script (make init) will validate all required values.
# Variables with defaults in parentheses are optional overrides.
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# AI Provider Selection
# Allowed values: ollama | byok
# ──────────────────────────────────────────────────────────────────────────────
PLATFORM_AI_PROVIDER=ollama

# ──────────────────────────────────────────────────────────────────────────────
# Ollama Configuration (required when PLATFORM_AI_PROVIDER=ollama)
# ──────────────────────────────────────────────────────────────────────────────
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ──────────────────────────────────────────────────────────────────────────────
# BYOK Configuration (required when PLATFORM_AI_PROVIDER=byok)
# Supports OpenAI, DeepSeek, Anthropic, or any OpenAI-compatible endpoint.
# ──────────────────────────────────────────────────────────────────────────────
BYOK_ENDPOINT=
BYOK_API_KEY=
BYOK_MODEL=
BYOK_PROVIDER_TYPE=OPENAI_COMPATIBLE

# ──────────────────────────────────────────────────────────────────────────────
# Kafka
# ──────────────────────────────────────────────────────────────────────────────
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ──────────────────────────────────────────────────────────────────────────────
# OpenSearch
# ──────────────────────────────────────────────────────────────────────────────
OPENSEARCH_URIS=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ──────────────────────────────────────────────────────────────────────────────
# MCP Server
# ──────────────────────────────────────────────────────────────────────────────
MCP_MODE=mock
MCP_PORT=3001
MCP_ALLOWED_NAMESPACES=default,chaos-validation
MCP_IDEMPOTENCY_TTL_SECONDS=300
PLATFORM_MCP_SERVER_URL=http://localhost:3001
MCP_CONNECTION_TIMEOUT=5
MCP_READ_TIMEOUT=10
MCP_MAX_PROMPT_BYTES=65536

# ──────────────────────────────────────────────────────────────────────────────
# Circuit Breakers (optional — sane defaults provided)
# ──────────────────────────────────────────────────────────────────────────────
# AI Provider CB
CB_AI_SLIDING_WINDOW=10
CB_AI_FAILURE_RATE=50
CB_AI_WAIT_DURATION=30
CB_AI_HALF_OPEN_CALLS=3

# MCP Read-Path CB
CB_MCP_SLIDING_WINDOW=10
CB_MCP_FAILURE_RATE=50
CB_MCP_WAIT_DURATION=30
CB_MCP_HALF_OPEN_CALLS=3

# Mutation Write-Path CB
CB_MUTATION_SLIDING_WINDOW=5
CB_MUTATION_FAILURE_RATE=50
CB_MUTATION_WAIT_DURATION=30
CB_MUTATION_HALF_OPEN_CALLS=2
